{
  "title": "CMS Test Page",
  "content": [
    {
      "type": "heading",
      "text": "Welcome to the CMS Page",
      "size": "4xl",
      "as": "h1"
    },
    {
      "type": "text",
      "size": "lg",
      "content": "This page was rendered from a JSON file generated by Sveltia CMS."
    },
    {
      "type": "stack",
      "direction": "vertical",
      "gap": "4",
      "children": [
        {
          "type": "heading",
          "text": "Interactive Components",
          "size": "2xl",
          "as": "h2"
        },
        {
          "type": "stack",
          "direction": "horizontal",
          "gap": "2",
          "children": [
            {
              "type": "button",
              "text": "Click Me",
              "variant": "solid",
              "colorPalette": "blue"
            },
            {
              "type": "badge",
              "text": "New",
              "variant": "subtle",
              "colorPalette": "green"
            }
          ]
        },
        {
          "type": "alert",
          "variant": "surface",
          "title": "Success",
          "description": "The page renderer is working correctly!",
          "status": "success"
        }
      ]
    },
    {
      "type": "badge",
      "text": "SSS",
      "variant": "solid",
      "colorPalette": "",
      "size": "md"
    }
  ]
}
