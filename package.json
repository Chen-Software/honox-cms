{
	"name": "artefact",
	"module": "src/main.ts",
	"type": "module",
	"private": true,
	"scripts": {
		"prepare": "panda codegen",
		"dev": "vite",
		"build": "vite build --mode client && vite build",
		"preview": "wrangler dev",
		"deploy": "bun run build && wrangler pages deploy ./dist",
		"fix": "bun run check",
		"check": "bun x @biomejs/biome check --fix .",
		"format": "bun x @biomejs/biome format --fix .",
		"lint": "bun x @biomejs/biome lint --fix .",
		"start": "bun run src/main.ts"
	},
	"dependencies": {
		"hono": "^4.12.31",
		"honox": "0.1.59"
	},
	"peerDependencies": {
		"typescript": "^6.0.2"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.4",
		"@hono/vite-build": "^1.11.1",
		"@hono/vite-dev-server": "^0.26.1",
		"@hono/vite-ssg": "^0.3.3",
		"@mdx-js/rollup": "^3.1.1",
		"@pandacss/dev": "^1.11.4",
		"@types/bun": "latest",
		"autoprefixer": "^10.5.4",
		"postcss": "^8.5.20",
		"remark-frontmatter": "^5.0.0",
		"remark-gfm": "^4.0.1",
		"remark-mdx-frontmatter": "^5.2.0",
		"vite": "^8.1.5",
		"wrangler": "^4.112.0"
	}
}
